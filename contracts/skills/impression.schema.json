{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lhrad:skill:impression.generate:output:1.0.0",
  "title": "impression.generate output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workflowId", "impressionText", "agentVersion", "generatedAt"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "workflowId": { "type": "string" },
    "impressionText": { "type": "string" },
    "structuredFindings": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": { "text": { "type": "string" }, "code": { "type": "string" } }
      }
    },
    "criticalFlags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label"],
        "properties": { "label": { "type": "string" }, "severity": { "type": "string" } }
      }
    },
    "agentVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" }
  }
}
