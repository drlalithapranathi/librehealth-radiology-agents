{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lhrad:skill:comms.dispatch:output:1.0.0",
  "title": "comms.dispatch output (existing Communications Agent, conformed to A2A)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workflowId", "dispatchStatus", "agentVersion", "dispatchedAt"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "workflowId": { "type": "string" },
    "dispatchStatus": { "type": "string", "enum": ["SENT", "QUEUED", "FAILED", "PARTIAL"] },
    "channelResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "status"],
        "properties": { "channel": { "type": "string" }, "status": { "type": "string" } }
      }
    },
    "agentVersion": { "type": "string" },
    "dispatchedAt": { "type": "string", "format": "date-time" }
  }
}
