{
  "name": "@lhrad/extension-worklist",
  "version": "0.1.0",
  "private": true,
  "description": "LH-Radiology OHIF extension: reading worklist (priority-ordered from Worklist API), priors and overlays panel, StudyOpenedEvent emitter. See docs/ohif-integration-approach.md for the R2 decision context.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "vitest run",
