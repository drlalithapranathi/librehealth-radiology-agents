    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "peerDependencies": {
    "@ohif/core": ">=3.6.0",
    "@ohif/ui": ">=3.6.0",
    "@ohif/extension-default": ">=3.6.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.8.1"
  },
  "peerDependenciesMeta": {
    "@ohif/core": { "optional": true },
    "@ohif/ui": { "optional": true },
    "@ohif/extension-default": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^12.1.5",
    "@types/react": "^17.0.75",
    "@types/react-dom": "^17.0.25",
    "@vitejs/plugin-react": "^4.2.1",
    "happy-dom": "^13.6.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.8.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "keywords": [
